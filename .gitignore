# Dependencies
node_modules/

# Build output (generated by docs:generate)
docs/.vitepress/dist/
docs/.vitepress/cache/
docs/.vitepress/config.ts
docs/index.md
docs/effects/
docs/public/effects/thumb/

# APK binary — too large for git
alightmotion.apk

# Decompiled APK — keep only what we use (effects XMLs, res/values, apktool.yml)
decompiled_apk/assets/audience_network/
decompiled_apk/assets/crisper/
decompiled_apk/assets/flutter_assets/
decompiled_apk/lib/
decompiled_apk/original/
decompiled_apk/res/
decompiled_apk/smali*/
decompiled_apk/unknown/
# Exclude all binary/obfuscated asset blobs (random-named files in assets root)
decompiled_apk/assets/[0-9A-Za-z][0-9A-Za-z][0-9A-Za-z][0-9A-Za-z][0-9A-Za-z][0-9A-Za-z][0-9A-Za-z][0-9A-Za-z]*
decompiled_apk/assets/*.gif
decompiled_apk/assets/*.json

# Keep:
# decompiled_apk/assets/effects/
# decompiled_apk/res/values/strings.xml  <- re-include below
# decompiled_apk/apktool.yml
!decompiled_apk/res/values/strings.xml

.DS_Store
*.log

# Ads/endcard templates
decompiled_apk/assets/fyb_*.html
# Zip bundles
decompiled_apk/assets/injet/
# Lottie assets (images)
decompiled_apk/assets/lottie/
# Shader files (not needed for docs)
decompiled_apk/assets/shaders/
# Dexopt / profiling
decompiled_apk/assets/dexopt/
# Device capability data
decompiled_apk/assets/data/

# Compiled DEX files
decompiled_apk/classes*.dex
