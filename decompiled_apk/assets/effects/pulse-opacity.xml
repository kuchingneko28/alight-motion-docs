<?xml version='1.0' encoding='UTF-8' ?>
<effect id="com.alightcreative.effects.pulseopacity" name="@am:string/effect_pulseopacity_name" desc="@am:string/effect_pulseopacity_desc" category="opacity" tags="opacity,visibility,auto,propAdjust" thumb="thumb/pulseopacity.webp" deprecated="true">

    <!--<strings>-->
        <!--<locale lang="en">-->
            <!--<string name="name">Pulse Opacity</string>-->
            <!--<string name="desc">Pulses the layer opacity over time, based on a sine or triangular wave. The frequency of pulsing can be adjusted.</string>-->
            <!--<string name="freq">Frequency</string>-->
            <!--<string name="strength">Strength</string>-->
            <!--<string name="wave">Wave</string>-->
            <!--<string name="sine">Sine</string>-->
            <!--<string name="triangle">Triangle</string>-->
            <!--<string name="phase">Phase</string>-->
        <!--</locale>-->
    <!--</strings>-->

    <params>
        <spinner id="freq" default="2.0" min="0.1" max="16.0" label="@am:string/effect_param_freq" />
        <spinner id="strength" default="1" min="0" max="1" label="@am:string/effect_param_strength" type="percent" />
        <slider id="phase" default="0" min="0" max="2" label="@am:string/effect_param_startphase" />
        <selector id="type" default="0" style="radio" label="@am:string/effect_param_wave" >
            <choice label="@am:string/effect_param_sine" value="0" />
            <choice label="@am:string/effect_param_triangle" value="1" />
        </selector>
    </params>

    <script lang="js"><![CDATA[

        function animate(env,el,p) {
            let t = env.time;
            let m
            if( p.type == 0 ) {
                m = Math.sin(((t * env.duration * p.freq)+p.phase) * 3.14159)
            } else {
                m = AM.triangle(((t * env.duration * p.freq)+p.phase) / 2.0)
            }
            m = (m + 1.0)/2.0;
            el.alpha *= (1-p.strength) + (m*p.strength);
            return el;
        }

    ]]></script>

</effect>
