<?xml version='1.0' encoding='UTF-8' ?>
<effect id="com.alightcreative.effects.randomdisplace" name="@am:string/effect_simplexdisplace_name" desc="@am:string/effect_simplexdisplace_desc" auto-transform="true" category="transform" tags="transform,shake,propAdjust,parenting,camera" thumb="thumb/simplexdisplace.webp">

    <params>
        <spinner id="mag" min="0" max="2000" step="1" default="50" label="@am:string/effect_param_mag" />
        <spinner id="evolution" min="0" max="2000" step="0.01" default="0" label="@am:string/effect_param_evolution" />
        <spinner id="seed" min="0" max="5" step="0.01" default="0" label="@am:string/effect_param_seed" />
        <spinner id="scatter" min="0" max="2" step="0.01" default="0.5" label="@am:string/effect_param_scatter" type="percent" />

        <!--<slider id="freq" default="2.0" min="0.05" max="16.0" label="@am:string/effect_param_freq" />-->
        <!--<slider id="mag" default="25" min="1" max="500" label="@am:string/effect_param_mag" />-->
        <!--<slider id="seed" default="0" min="0" max="10" label="@am:string/effect_param_seed" />-->
        <!--<selector id="basis" default="0" style="radio" label="@am:string/effect_param_basis" >-->
            <!--<choice label="@am:string/effect_param_time" value="0" />-->
            <!--<choice label="@am:string/effect_param_position" value="1" />-->
        <!--</selector>-->

    </params>

    <script lang="js"><![CDATA[

        function animate(env,el,p) {
            let dx = AM.simplexNoise(el.transform.location.x * p.scatter / 50.0 + p.seed*54623.245, el.transform.location.y * p.scatter / 500.0, p.evolution + p.seed*49235.319798);
            let dy = AM.simplexNoise(el.transform.location.x * p.scatter / 50.0, el.transform.location.y * p.scatter / 500.0 + p.seed*8723.5647, p.evolution+7468.329 + p.seed*19337.940385);
            dx *= p.mag;
            dy *= p.mag;
            el.transform.location.x += dx;
            el.transform.location.y += dy;
            return el;
        }

    ]]></script>

</effect>
