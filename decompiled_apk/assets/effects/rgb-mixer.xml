<?xml version='1.0' encoding='UTF-8' ?>
<effect id="com.alightcreative.effects.rgb-mixer" name="@am:string/effect_rgb_mixer_name" desc="@am:string/effect_rgb_mixer_desc" category="color" tags="raster,blur" thumb="thumb/glowscan.webp" experimental="true">

    <params>
        <texture id="inputImg" srcType="content" />
        <color id="rmix" default="#FFFF0000" label="@am:string/effect_param_red" alpha="false" />
        <color id="gmix" default="#FF00FF00" label="@am:string/effect_param_green" alpha="false" />
        <color id="bmix" default="#FF0000FF" label="@am:string/effect_param_blue" alpha="false" />
        <spinner id="gamma" default="1.0" min="0.01" max="9.99" label="@am:string/effect_param_gamma" logscale="2.351" snap="1.0" ticks="0.5,1.0,2.0" step="0.005" />
        <spinner id="offset" default="0.0" min="-0.9" max="0.9" label="@am:string/effect_param_offset" ticks="0.0" snap="0.0" step="0.01" />
    </params>

    <shader type="fragment" precision="high"><![CDATA[


        void main() {
        
            vec4 texColor = texture2DCv(inputImg.texture,acScreenNorm);
            vec3 rgb = texColor.rgb / max(texColor.a,0.00001);
            vec4 result = rgb.r * rmix + rgb.g * gmix + rgb.b * bmix;
            result.rgb = pow(result.rgb,vec3(1.0/gamma));
            result.rgb += offset;
            gl_FragColor = vec4(saturate(result.rgb),1.)*texColor.a;
        
        }

    ]]></shader>

</effect>
