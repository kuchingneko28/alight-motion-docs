<?xml version='1.0' encoding='UTF-8' ?>
<effect id="com.alightcreative.effects.rgb-gamma" name="@am:string/effect_rgb_gamma_name" desc="@am:string/effect_rgb_gamma_desc" category="color" tags="raster,blur" thumb="thumb/glowscan.webp" experimental="true">

    <params>
        <texture id="inputImg" srcType="content" />
        <spinner id="redGamma" default="1.0" min="0.01" max="9.99" label="@am:string/effect_param_red_gamma" logscale="2.351" snap="1.0" ticks="0.5,1.0,2.0" step="0.005" />
        <spinner id="greenGamma" default="1.0" min="0.01" max="9.99" label="@am:string/effect_param_green_gamma" logscale="2.351" snap="1.0" ticks="0.5,1.0,2.0" step="0.005" />
        <spinner id="blueGamma" default="1.0" min="0.01" max="9.99" label="@am:string/effect_param_blue_gamma" logscale="2.351" snap="1.0" ticks="0.5,1.0,2.0" step="0.005" />
    </params>

    <shader type="fragment" precision="high"><![CDATA[


        void main() {
        
            vec4 texColor = texture2DCv(inputImg.texture,acScreenNorm);
            texColor.rgb = pow(texColor.rgb,vec3(1.0/redGamma,1.0/greenGamma,1.0/blueGamma));
            gl_FragColor = texColor;
        
        }

    ]]></shader>

</effect>

