        <spinner id="angle" default="0.0" min="-1800.0" max="1800.0" label="@am:string/effect_param_angle" ticks="-90,-45,0,45,90" snap="-90,-45,0,45,90" type="angle" step="0.1" />
        <spinner id="scale" default="1.0" min="0" max="10.0" label="@am:string/effect_param_scale" ticks="0.25,0.5,0.75,1,2" snap="-90,-45,0,45,90" step="0.01" />
        <spinner id="alpha" default="1" min="0" max="1" step="0.001" label="@am:string/effect_param_alpha" type="percent" />
    </params>

</effect>
