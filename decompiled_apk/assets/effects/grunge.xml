    <passes>
        <pass target="blurBuf" effect="com.alightcreative.effects.gaussianblur"/>
        <pass />
    </passes>

    <shader type="fragment" precision="high"><![CDATA[

        const vec3 luminanceWeighting = vec3(0.2126, 0.7152, 0.0722);

        mat2 rot2(float a) {
            float c = cos(a);
            float s = sin(a);
            return mat2(c,s,-s,c);
        }

        vec4 composite( vec4 a, vec4 b) {
            return a * (1. - b.a) + b;
        }

        float sampleGrain(vec2 uv, int grainType, float gamma, float contrast, float scale, float angle, vec2 offset, bool invert) {

            uv -= 0.5;
            uv *= rot2(angle*0.0174533);
            uv /= scale;
            uv += 0.5;
            uv -= offset * vec2(1., -1.) / 500.;
            uv = fract(uv);

            float grainLuma;
            if( grainType == 1 ) {
                grainLuma = texture2D(grunge_a.texture,uv).r;
            } else if( grainType == 2 ) {
                grainLuma = texture2D(grunge_a.texture,uv).g;
            } else if( grainType == 3 ) {
                grainLuma = texture2D(grunge_a.texture,uv).b;
            } else if( grainType == 4 ) {
                grainLuma = texture2D(grunge_b.texture,uv).r;
            } else if( grainType == 5 ) {
                grainLuma = texture2D(grunge_b.texture,uv).g;
            } else if( grainType == 6 ) {
                grainLuma = texture2D(grunge_b.texture,uv).b;
            } else if( grainType == 7 ) {
                grainLuma = dot(texture2D(grunge_a.texture,uv).rgb, vec3(1.)) / 3.;
            } else if( grainType == 8 ) {
                grainLuma = dot(texture2D(grunge_b.texture,uv).rgb, vec3(1.)) / 3.;
            } else if( grainType == 9 ) {
                grainLuma = dot(texture2D(grunge_b.texture,uv).rb, vec2(1.)) / 2.;
            } else if( grainType == 10 ) {
                uv *= 16.;
                vec2 st = fract(uv);
                vec2 id = floor(uv);
                if( mod(id.x + id.y,2.) == 0. ) {
                    st = st.yx;
                }
                float pp = 6.;
                float p = pow(sin(st.x*3.14159*1.),pp);
                st = st.yx;
                float q = clamp(pow(sin(st.x*3.14159*1.),pp),0.,1.);
                p += q * pow((1.-p),10.);
                grainLuma = p;
            } else if( grainType == 11 ) {
                vec2 st = uv * 16.;
                vec2 id = floor(st);
                st = fract(st);
                if( mod(id.x + id.y,2.) == 0. ) {
                    st = st.yx;
                }
                float pp = 6.;
                float p = pow(sin(st.x*3.14159*1.),pp);
                st = st.yx;
                float q = clamp(pow(sin(st.x*3.14159*1.),pp),0.,1.);
                p += q * pow((1.-p),10.);
                p = saturate(p);
                float tc = texture2D(grunge_b.texture,uv).b;
                grainLuma = p * abs(p-tc); //p - (tc * (1.-p));
            } else if( grainType == 12 ) {
                grainLuma = sin(uv.y*30.*3.14159)*0.5+0.5;
            } else if( grainType == 13 ) {
                grainLuma = min(sin(uv.y*30.*3.14159)*0.5+0.5,sin(uv.x*30.*3.14159)*0.5+0.5);
            } else if( grainType == 14 ) {
                grainLuma = (sin(uv.y*30.*3.14159)*sin(uv.x*30.*3.14159))*0.5+0.5;
            } else if( grainType == 15 ) {
                grainLuma = uv.y;
            } else if( grainType == 16 ) {
                grainLuma = 1.0;
            } else {
                grainLuma = 0.5;
            }

            grainLuma = saturate(((grainLuma-0.5) * (1.+contrast)) + 0.5);
            grainLuma = pow(grainLuma,1.0/gamma);
            if( invert )
                grainLuma = 1.-grainLuma;

            return grainLuma;

        }

        vec2 applyDisplace(vec2 displace, vec4 blurColor, vec2 offset, bool fromCtr, int region, vec2 uv, int grainType, float gamma, float contrast, float scale, float angle, vec2 texOffset) {

            float p;
            if( region == 1) {  // Edge
                p = 1. - saturate((blurColor.a-0.5) * 2.);
            } else if( region == 2 ) {  // Center
                p = saturate((blurColor.a-0.5) * 2.);
            } else if( region == 3 ) {  // Fill
                p = 1.;
            } else {
                p = 0.;
            }

            float g = sampleGrain( uv, grainType, gamma, contrast, scale, angle, texOffset, false);

            if( fromCtr ) {
                g = (g - 0.5) * 2.;
            }

            return displace + (offset * vec2(1.,-1.) / 2000.) * g * p;
        }

        vec4 blendGrain(vec4 baseColor, vec4 originalColor, vec4 blurColor, vec4 color, float alpha, int blendMode, int region, float spread, float rawChoke, float burn, vec2 uv, int grainType, float gamma, float contrast, float scale, float angle, vec2 offset, bool invert, bool light, float lightAngle) {

            float choke = clamp(rawChoke,0.,0.999);

            float p;
            float m;
            if( region == 1) {  // Edge
                m = baseColor.a;
                p = 1. - saturate((blurColor.a-0.5) * 2.);
            } else if( region == 2 ) {  // Center
                m = baseColor.a;
                p = saturate((blurColor.a-0.5) * 2.);
            } else if( region == 3 ) {  // Fill
                m = baseColor.a;
                p = 1.;
            } else if( region == 4 ) {  // Glow
                m = 1.-baseColor.a;
                p = saturate(blurColor.a * 2. - baseColor.a);
            } else {
                m = 0.;
                p = 0.;
            }

            p = saturate((p-choke)/(max(1.-spread,choke+0.0001)-choke));
            float g;
            if( light ) {
                vec2 lv = vec2(.002, 0.) * rot2(lightAngle*0.0174533);
                float g1 = sampleGrain( uv+lv, grainType, gamma, contrast, scale, angle, offset, invert);
                float g2 = sampleGrain( uv-lv, grainType, gamma, contrast, scale, angle, offset, invert);
                g = saturate((g1-g2)*5.);
            } else {
                g = sampleGrain( uv, grainType, gamma, contrast, scale, angle, offset, invert);
            }

            vec4 c = color;
            if( burn < 0.0 ) {
                c.rgb = mix(c.rgb, 1.-(1.-c.rgb) * (1.-(0.5+c.rgb*0.5)), -burn * g*g );
            } else {
                c.rgb = mix(c.rgb, c.rgb * c.rgb * 0.25, burn * g * g );
            }
            c *= alpha * p * g;

            if( region==4 ) {
                return composite(baseColor,c * m);
            } else if( blendMode==1 ) { // Multiply
                vec3 baseRgb = baseColor.rgb / max(baseColor.a,0.00001);;
                vec3 rgb = c.rgb / max(c.a,0.00001);
                vec3 adj = baseRgb * rgb;
                return composite(baseColor,vec4(adj,1.) * c.a * baseColor.a);
            } else if( blendMode==2 ) { // Screen
                vec3 baseRgb = baseColor.rgb / max(baseColor.a,0.00001);;
                vec3 rgb = c.rgb / max(c.a,0.00001);
                vec3 adj = 1. - ((1.-baseRgb) * (1.-rgb));
                return composite(baseColor,vec4(adj,1.) * c.a * baseColor.a);
            } else if( blendMode==3 ) { // Punch out
                return baseColor * (1.-c.a);
            } else if( blendMode==4 ) { // Punch out
                return composite(baseColor,originalColor * (c.a * m));
            } else { // Normal
                return composite(baseColor,c * m);
            }

        }

        void main() {

            vec4 blurTexColor = texture2DCv(blurBuf.texture,acScreenNorm);
            vec2 uv = acLayerNorm;
            uv.x *= acLayerSize.x / acLayerSize.y;

            vec2 displace = vec2(0.);

            displace = applyDisplace(displace,blurTexColor,d1offset,d1fromctr,d1region,uv,int(d1grain),d1gamma,d1contrast,d1scale,d1angle,d1toffset);
            uv += displace;
            displace = applyDisplace(displace,blurTexColor,d2offset,d2fromctr,d2region,uv,int(d2grain),d2gamma,d2contrast,d2scale,d2angle,d2toffset);
            uv += displace;

            displace.x *= acScreenSize.x / acScreenSize.y;

            vec4 texColor = texture2DCv(inputImg.texture,acScreenNorm + displace);

            texColor = mix(texColor,fillColor*texColor.a,fillColorBlend);

            vec4 result = texColor;

            result = blendGrain(result, texColor, blurTexColor, t1color, t1alpha, t1blendMode, t1active ? t1region : 0, t1spread, t1choke, t1burn, uv, int(t1grain), t1gamma, t1contrast, t1scale, t1angle, t1offset, t1invert, t1light, t1lightAngle);
            result = blendGrain(result, texColor, blurTexColor, t2color, t2alpha, t2blendMode, t2active ? t2region : 0, t2spread, t2choke, t2burn, uv, int(t2grain), t2gamma, t2contrast, t2scale, t2angle, t2offset, t2invert, t2light, t2lightAngle);
            result = blendGrain(result, texColor, blurTexColor, t3color, t3alpha, t3blendMode, t3active ? t3region : 0, t3spread, t3choke, t3burn, uv, int(t3grain), t3gamma, t3contrast, t3scale, t3angle, t3offset, t3invert, t3light, t3lightAngle);
            result = blendGrain(result, texColor, blurTexColor, t4color, t4alpha, t4blendMode, t4active ? t4region : 0, t4spread, t4choke, t4burn, uv, int(t4grain), t4gamma, t4contrast, t4scale, t4angle, t4offset, t4invert, t4light, t4lightAngle);
            result = blendGrain(result, texColor, blurTexColor, t5color, t5alpha, t5blendMode, t5active ? t5region : 0, t5spread, t5choke, t5burn, uv, int(t5grain), t5gamma, t5contrast, t5scale, t5angle, t5offset, t5invert, t5light, t5lightAngle);
            result = blendGrain(result, texColor, blurTexColor, t6color, t6alpha, t6blendMode, t6active ? t6region : 0, t6spread, t6choke, t6burn, uv, int(t6grain), t6gamma, t6contrast, t6scale, t6angle, t6offset, t6invert, t6light, t6lightAngle);
            result = blendGrain(result, texColor, blurTexColor, t7color, t7alpha, t7blendMode, t7active ? t7region : 0, t7spread, t7choke, t7burn, uv, int(t7grain), t7gamma, t7contrast, t7scale, t7angle, t7offset, t7invert, t7light, t7lightAngle);
            result = blendGrain(result, texColor, blurTexColor, t8color, t8alpha, t8blendMode, t8active ? t8region : 0, t8spread, t8choke, t8burn, uv, int(t8grain), t8gamma, t8contrast, t8scale, t8angle, t8offset, t8invert, t8light, t8lightAngle);

            gl_FragColor = result;

        }

    ]]></shader>

