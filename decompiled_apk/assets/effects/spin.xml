<effect id="com.alightcreative.effects.spin" name="@am:string/effect_spin_name" desc="@am:string/effect_spin_desc" auto-transform="true" category="transform" tags="trasform,auto,propAdjust,parenting,camera" thumb="thumb/spin.webp">

    <params>
