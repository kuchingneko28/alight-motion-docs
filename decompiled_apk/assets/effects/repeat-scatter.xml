<?xml version='1.0' encoding='UTF-8' ?>
<effect id="com.alightcreative.effects.repeat.scatter" name="@am:string/effect_repeatscatter_name" desc="@am:string/effect_repeatscatter_desc" category="repeat" tags="repeat,membersOnly,random" thumb="thumb/repeat-scatter.png">

    <!--<strings>-->
        <!--<locale lang="en">-->
            <!--<string name="name">Drawing Progress</string>-->
            <!--<string name="desc">Drawing Progress</string>-->
        <!--</locale>-->
    <!--</strings>-->

    <params>
        <spinner id="count" default="20" min="0" max="150" step="1" label="@am:string/effect_param_count" />
        <spinner id="radius" default="300" min="0" max="2000.0" label="@am:string/effect_param_radius" step="1" />
        <spinner id="evolution" min="0" max="2000" step="0.01" default="0" label="@am:string/effect_param_evolution" />
        <spinner id="scatterSeed" min="0" max="5" step="0.01" default="0" label="@am:string/effect_param_seed" />

        <section text="@am:string/effect_section_rangetransform" />
        <point id="offset" default="0.0,0.0" label="@am:string/effect_param_offset" />
        <spinner id="angle" default="0.0" min="-1800.0" max="1800.0" label="@am:string/effect_param_angle" ticks="-90,-45,0,45,90" snap="-90,-45,0,45,90" type="angle" step="1" />
        <spinner id="scale" default="1.0" min="0" max="10.0" label="@am:string/effect_param_scale" ticks="0.25,0.5,0.75,1,2" snap="-90,-45,0,45,90" step="0.01" />
        <spinner id="alpha" default="1" min="0" max="1" step="0.001" label="@am:string/effect_param_alpha" />
        <section text="@am:string/effect_param_fillColor" />
        <color id="fillColor" default="#FF2D1EF6" label="@am:string/effect_param_color" alpha="false" />
        <slider id="blend" default="0.00" min="0.0" max="2" ticks="1" snap="1" label="@am:string/effect_param_blend" />
        <switch id="colorAltCopies" default="false" label="@am:string/effect_param_altCopies" />

        <section text="@am:string/effect_param_range" />
        <spinner id="start" default="0.0" min="0.0" max="1.0" type="percent" step="0.001" label="@am:string/effect_param_start" ticks="0.0,0.5,1.0" />
        <spinner id="end" default="1.0" min="0.0" max="1.0"  type="percent" step="0.001"  label="@am:string/effect_param_end" ticks="0.0,0.5,1.0" />
        <spinner id="phase" default="0.0" min="-1.0" max="2.0" type="percent"  step="0.001" label="@am:string/effect_param_phase" ticks="-1.0,0.0,1.0" />

        <section text="@am:string/effect_section_interpease" />
        <slider id="easeIn" default="0" min="-1" max="1" label="@am:string/effect_param_ease_in" step="0.01" type="percent" snap="0" ticks="0" />
        <slider id="easeOut" default="0" min="-1" max="1" label="@am:string/effect_param_ease_out" step="0.01" type="percent" snap="0" ticks="0"  />
        <spinner id="overlap" default="0" min="0" max="10" label="@am:string/effect_param_overlap" step="0.01" type="percent" />
        <selector id="shape" default="0" style="radio" label="@am:string/effect_param_shape" >
            <choice label="@am:string/effect_param_ramp" value="0" />
            <choice label="@am:string/effect_param_square" value="1" />
            <choice label="@am:string/effect_param_smooth" value="2" />
            <choice label="@am:string/effect_param_triangle" value="3" />
        </selector>
        <switch id="invert" default="false" label="@am:string/effect_param_invert" />

        <section text="@am:string/effect_param_random_order" />
        <switch id="randomOrder" default="false" label="@am:string/effect_param_random_order" />
        <spinner id="seed" default="0.0" min="0.0" max="5.0" step="0.01" label="@am:string/effect_param_seed" />

        <!--<section text="@am:string/effect_param_timeShift" />-->
        <!--<spinner id="timeShift" default="0" min="0" max="9999" step="0.1" label="@am:string/effect_param_offset" type="seconds" />-->
    </params>

</effect>
